FROM python:3.12-slim

WORKDIR /app
COPY pyproject.toml /app/pyproject.toml
RUN pip install --no-cache-dir -U pip && pip install --no-cache-dir -e .[dev]
COPY . /app
ENV PYTHONPATH=/app/apps/api/src:/app/services/executor/src:/app/services/strategy/src:/app/services/backtest/src:/app/services/training/src:/app/libs/common/src
