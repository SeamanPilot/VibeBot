//@version=6
indicator("Futures AI Signal Relay", overlay=true)

shared_secret = input.string("change-me", "Shared Secret")
symbol_root = input.string("ES", "Symbol Root")
timeframe_label = input.string("1m", "Timeframe")
fast_len = input.int(9, "Fast EMA")
slow_len = input.int(21, "Slow EMA")

fast = ta.ema(close, fast_len)
slow = ta.ema(close, slow_len)
long_signal = ta.crossover(fast, slow)
short_signal = ta.crossunder(fast, slow)

plot(fast, color=color.new(color.green, 0))
plot(slow, color=color.new(color.red, 0))

if long_signal
    payload = '{"secret":"' + shared_secret + '","event_type":"signal_only","symbol":"' + symbol_root + '","timeframe":"' + timeframe_label + '","action":"LONG_ENTRY","timestamp":"{{timenow}}","price":{{close}},"confidence":0.60}'
    alert(payload, alert.freq_once_per_bar_close)

if short_signal
    payload = '{"secret":"' + shared_secret + '","event_type":"signal_only","symbol":"' + symbol_root + '","timeframe":"' + timeframe_label + '","action":"SHORT_ENTRY","timestamp":"{{timenow}}","price":{{close}},"confidence":0.60}'
    alert(payload, alert.freq_once_per_bar_close)
